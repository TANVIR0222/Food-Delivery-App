{
  "expo": {
    "name": "Food Delivery",
    "slug": "food-delivery",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-logo/app-logo.png",
    "scheme": "food-delivery",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/app-logo/app-logo.png",
        "backgroundImage": "./assets/app-logo/app-logo.png",
        "monochromeImage": "./assets/app-logo/app-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tanvir_islam002.food_delivery"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/app-logo/app-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF",
          "android": {
            "image": "./assets/app-logo/app-logo.png",
            "imageWidth": 200,
            "imageHeight": 200
          }
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access your Face ID biometric data."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
